# Desenvolvimento local — proxy do Vite cuida do redirecionamento
# Deixe vazio ou aponte para o backend local
VITE_API_URL=

# WebSocket — só funciona em dev local (Vercel serverless não suporta WS)
VITE_WS_URL=http://localhost:3001

# Produção (Vercel) — não precisa setar VITE_API_URL
# A API fica em /api no mesmo domínio
