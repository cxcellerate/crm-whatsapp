# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=troque_por_uma_chave_segura_aleatoria
JWT_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# Banco de dados (PostgreSQL)
# Local:   postgresql://crmuser:crmpassword@localhost:5432/crmwhatsapp
# Vercel:  use Neon (neon.tech) — grátis, serverless-friendly
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://crmuser:crmpassword@localhost:5432/crmwhatsapp"

# ─────────────────────────────────────────────
# Redis (apenas para dev local / Bull)
# No Vercel não é suportado em serverless
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# WhatsApp — Evolution API
# ─────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution_api

# ─────────────────────────────────────────────
# Meta Ads (opcional)
# ─────────────────────────────────────────────
META_ACCESS_TOKEN=
META_APP_ID=

# ─────────────────────────────────────────────
# Google Ads (opcional)
# ─────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ─────────────────────────────────────────────
# Frontend (CORS)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────
# Segurança de Webhooks
# Configure o mesmo valor que estiver no painel de cada provedor.
# Se deixar em branco, o webhook aceita sem verificação (apenas para dev).
# ─────────────────────────────────────────────
# Evolution API: Global API Key definida no painel
EVOLUTION_WEBHOOK_TOKEN=
# Z-API: Client-Token da sua instância (aba Configurações > Webhooks)
ZAPI_WEBHOOK_TOKEN=
