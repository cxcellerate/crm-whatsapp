generator client {
  provider      = "prisma-client-js"
  // Necessário para deploy serverless (Vercel, AWS Lambda, etc.)
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SELLER)
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads      Lead[]
  messages   Message[]
  activities Activity[]

  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  SELLER
}

model Pipeline {
  id        String   @id @default(uuid())
  name      String
  order     Int      @default(0)
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages Stage[]

  @@map("pipelines")
}

model Stage {
  id         String   @id @default(uuid())
  name       String
  order      Int      @default(0)
  color      String   @default("#6366f1")
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  leads Lead[]

  @@map("stages")
}

model Lead {
  id          String     @id @default(uuid())
  name        String
  phone       String
  email       String?
  company     String?
  value       Float?
  notes       String?
  stageId     String
  stage       Stage      @relation(fields: [stageId], references: [id])
  assignedTo  String?
  user        User?      @relation(fields: [assignedTo], references: [id])
  source      LeadSource @default(MANUAL)
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  tags        String[]
  lostReason  String?
  wonAt       DateTime?
  lostAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  messages   Message[]
  activities Activity[]
  aiSessions AiAgentSession[]

  @@map("leads")
}

enum LeadSource {
  MANUAL
  FORM
  WHATSAPP
  GOOGLE_ADS
  META_ADS
  ORGANIC
  REFERRAL
}

model Message {
  id          String        @id @default(uuid())
  leadId      String
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  content     String
  type        MessageType   @default(TEXT)
  direction   Direction     @default(OUTBOUND)
  status      MessageStatus @default(SENT)
  waMessageId String? @unique
  mediaUrl    String?
  createdAt   DateTime      @default(now())

  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Activity {
  id        String       @id @default(uuid())
  leadId    String
  lead      Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
  type      ActivityType
  content   String
  createdAt DateTime     @default(now())

  @@map("activities")
}

enum ActivityType {
  NOTE
  STAGE_CHANGE
  MESSAGE_SENT
  MESSAGE_RECEIVED
  CALL
  MEETING
  EMAIL
  TASK
}

// Configurações gerais do sistema (chave-valor)
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Sessão de conversa do agente de IA
model AiAgentSession {
  id            String          @id @default(uuid())
  phone         String          @unique
  leadId        String?
  lead          Lead?           @relation(fields: [leadId], references: [id])
  status        AiSessionStatus @default(ACTIVE)
  extractedData Json            @default("{}")
  turnCount     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  messages AiAgentMessage[]

  @@map("ai_agent_sessions")
}

model AiAgentMessage {
  id        String         @id @default(uuid())
  sessionId String
  session   AiAgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime       @default(now())

  @@map("ai_agent_messages")
}

enum AiSessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model FormCapture {
  id         String   @id @default(uuid())
  name       String
  token      String   @unique @default(uuid())
  pipelineId String?
  stageId    String?
  assignTo   String?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("form_captures")
}
